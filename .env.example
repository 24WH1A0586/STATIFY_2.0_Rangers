# ─────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# Your Hugging Face API token (required)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# (Optional) Override the default open-source model.
# Must be a text-generation model hosted on Hugging Face Hub
# that supports the InferenceAPI (Serverless or Dedicated Endpoint).
# Default: mistralai/Mistral-7B-Instruct-v0.3
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
